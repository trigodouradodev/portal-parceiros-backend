# App
NODE_ENV=development
PORT=3000

# CORS allowed origins (comma-separated, no trailing slash)
CORS_ORIGINS=http://localhost:5173,https://portal-parceiros.trigo.com.br

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trigo_dourado

# Connection string used by Prisma (build it from the values above)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trigo_dourado?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRES_IN=7d

# Geocoding (location-check) — Google Maps Geocoding API key.
# Vazio desabilita o endpoint POST /location-check (responde 503).
GOOGLE_MAPS_API_KEY=
# Raio máximo (metros) aceito na verificação. Default 15. Geocoding raramente
# atinge 15m em endereço BR — aumente (ex.: 100) se houver muitos falsos negativos.
LOCATION_CHECK_RADIUS_METERS=15
